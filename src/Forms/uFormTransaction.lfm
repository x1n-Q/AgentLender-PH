      Left = 24
      Height = 17
      Top = 350
      Width = 500
      Caption = ''
      Font.Color = clMaroon
      Font.Style = [fsItalic]
      ParentColor = False
      ParentFont = False
    end
    object ComboType: TComboBox
      Left = 24
      Height = 25
      Top = 50
      Width = 280
      Style = csDropDownList
