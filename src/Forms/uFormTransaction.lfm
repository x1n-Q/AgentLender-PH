    TabOrder = 0
    object LabelType: TLabel
      Left = 24
      Height = 17
      Top = 32
      Width = 30
      Caption = 'Type'
      ParentColor = False
    end
    object LabelAmount: TLabel
      Left = 24
      Height = 17
      Top = 80
      Width = 50
      Caption = 'Amount'
      ParentColor = False
    end
    object LabelFee: TLabel
      Left = 240
      Height = 17
      Top = 80
      Width = 24
      Caption = 'Fee'
      ParentColor = False
    end
    object LabelCustomer: TLabel
