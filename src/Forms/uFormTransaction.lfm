object FormTransaction: TFormTransaction
  Left = 0
  Top = 0
  Caption = 'New Transaction'
  ClientHeight = 480
  ClientWidth = 600
  BorderStyle = bsDialog
  Position = poMainFormCenter
  OnShow = FormShow
  LCLVersion = '3.0'
  object GroupBoxTxn: TGroupBox
    Left = 16
