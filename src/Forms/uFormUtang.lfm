      TabOrder = 2
      OnClick = ButtonPayClick
    end
    object ButtonRefresh: TButton
      Left = 660
      Height = 36
      Top = 100
      Width = 100
      Caption = 'Refresh'
      TabOrder = 3
      OnClick = ButtonRefreshClick
    end
    object ButtonClose: TButton
      Left = 770
      Height = 36
      Top = 100
      Width = 100
      Caption = 'Close'
      TabOrder = 4
      OnClick = ButtonCloseClick
    end
  end
  object StringGridUtang: TStringGrid
    Left = 0
    Height = 330
    Top = 50
    Width = 880
    Align = alClient
    ColCount = 6
    DefaultColWidth = 130
    DefaultRowHeight = 22
    FixedCols = 0
    RowCount = 2
    Options = [goFixedVertLine, goFixedHorzLine, goVertLine, goHorzLine, goRangeSelect, goRowSelect]
    TabOrder = 2
