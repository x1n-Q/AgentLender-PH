    object LabelHeader: TLabel
      Left = 16
      Height = 19
      Top = 16
      Width = 320
      Caption = 'Outstanding customer utang (debts)'
      Font.Height = -13
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
  end
  object PanelPay: TPanel
    Left = 0
    Height = 160
    Top = 380
    Width = 880
    Align = alBottom
    BevelOuter = bvNone
    TabOrder = 1
    object LabelSelected: TLabel
      Left = 16
      Height = 17
      Top = 12
      Width = 280
      Caption = 'Select a utang from the list above.'
      ParentColor = False
    end
    object LabelAmount: TLabel
      Left = 16
      Height = 17
      Top = 44
      Width = 110
      Caption = 'Payment amount'
      ParentColor = False
    end
    object LabelNotes: TLabel
      Left = 240
      Height = 17
      Top = 44
      Width = 35
      Caption = 'Notes'
      ParentColor = False
    end
    object EditAmount: TEdit
      Left = 16
      Height = 25
      Top = 64
      Width = 200
      TabOrder = 0
    end
    object EditNotes: TEdit
      Left = 240
      Height = 25
      Top = 64
      Width = 420
      TabOrder = 1
    end
    object ButtonPay: TButton
      Left = 16
      Height = 36
      Top = 100
      Width = 200
      Caption = 'Record Payment'
