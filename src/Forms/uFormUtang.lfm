object FormUtang: TFormUtang
  Left = 0
  Top = 0
  Caption = 'Utang (Customer Debts)'
  ClientHeight = 540
  ClientWidth = 880
  Position = poMainFormCenter
  OnShow = FormShow
  LCLVersion = '3.0'
  object PanelTop: TPanel
    Left = 0
    Height = 50
    Top = 0
    Width = 880
    Align = alTop
    BevelOuter = bvNone
